// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?
  role     String  @default("USER")

  // Profile fields
  bio             String?
  avatarUrl       String?
  locationEnabled Boolean @default(false)
  distanceVisibility Boolean @default(true)
  activityVisibility Boolean @default(true)

  // Geo-location fields
  latitude  Float?
  longitude Float?

  interests UserInterest[]

  // Interactions where this user is the actor
  sentInteractions     Interaction[] @relation("ActorInteractions")
  // Interactions where this user is the target
  receivedInteractions Interaction[] @relation("TargetInteractions")

  // Matches where this user is user1
  matchesInitiated MatchUnlock[] @relation("MatchUser1")
  // Matches where this user is user2
  matchesReceived  MatchUnlock[] @relation("MatchUser2")

  media             Media[]
  interestPosts     InterestPost[]
  postLikes         PostLike[]
  sentMessages      Message[]
  viewerImpressions FeedImpression[] @relation("ViewerImpressions")
  targetImpressions FeedImpression[] @relation("TargetImpressions")

  blocksInitiated   Block[] @relation("BlocksInitiated")
  blocksReceived    Block[] @relation("BlocksReceived")

  reportsInitiated  Report[] @relation("ReportsInitiated")
  reportsReceived   Report[] @relation("ReportsReceived")

  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([latitude, longitude])
  @@index([lastActiveAt])
  @@index([distanceVisibility])
  @@index([activityVisibility])
}

model Interest {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  parentId String?
  parent   Interest?  @relation("InterestHierarchy", fields: [parentId], references: [id])
  children Interest[] @relation("InterestHierarchy")

  // Usage stats for rarity boost
  usageCount Int @default(0)

  users UserInterest[]
  posts InterestPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Join table for User and Interest (many-to-many with explicit model)
model UserInterest {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interestId String
  interest   Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  // Optional: weight or proficiency level
  level Int? @default(1)

  createdAt DateTime @default(now())

  @@unique([userId, interestId])
  @@index([userId])
  @@index([interestId])
}

model Interaction {
  id String @id @default(uuid())

  actorId String
  actor   User   @relation("ActorInteractions", fields: [actorId], references: [id], onDelete: Cascade)

  targetId String
  target   User   @relation("TargetInteractions", fields: [targetId], references: [id], onDelete: Cascade)

  type InteractionType

  createdAt DateTime @default(now())

  @@unique([actorId, targetId])
  // A user can typically only have one active interaction type towards another user
  @@index([actorId])
  @@index([targetId])
}

enum InteractionType {
  LIKE
  PASS
  SUPERLIKE
}

model MatchUnlock {
  id String @id @default(uuid())

  user1Id String
  user1   User   @relation("MatchUser1", fields: [user1Id], references: [id], onDelete: Cascade)

  user2Id String
  user2   User   @relation("MatchUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  messages Message[]

  @@unique([user1Id, user2Id])
}

model Media {
  id        String   @id @default(uuid())
  userId    String
  url       String
  type      String // image | video
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id])
  interestPosts InterestPost[]
}

model InterestPost {
  id         String   @id @default(uuid())
  userId     String
  interestId String
  mediaId    String?
  caption    String?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  interest Interest @relation(fields: [interestId], references: [id])
  media    Media?   @relation(fields: [mediaId], references: [id])
  likes    PostLike[]

  @@index([userId])
  @@index([interestId])
}

model FeedImpression {
  id       String   @id @default(uuid())
  viewerId String
  targetId String
  shownAt  DateTime @default(now())

  viewer User @relation("ViewerImpressions", fields: [viewerId], references: [id], onDelete: Cascade)
  target User @relation("TargetImpressions", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([viewerId, targetId])
  @@index([viewerId, shownAt])
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  likerId   String
  createdAt DateTime @default(now())

  post      InterestPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  liker     User         @relation(fields: [likerId], references: [id], onDelete: Cascade)

  @@unique([postId, likerId])
  @@index([likerId])
  @@index([postId])
}

model Message {
  id        String   @id @default(uuid())
  matchId   String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  match     MatchUnlock @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender    User        @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
  @@index([senderId])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlocksInitiated", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Report {
  id            String         @id @default(uuid())
  reporterId    String
  reportedId    String
  category      ReportCategory
  description   String?
  screenshotUrl String?
  status        ReportStatus   @default(PENDING)
  createdAt     DateTime       @default(now())

  reporter User @relation("ReportsInitiated", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("ReportsReceived", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([reportedId])
  @@index([status])
}

enum ReportCategory {
  SPAM
  FAKE_PROFILE
  INAPPROPRIATE_CONTENT
  HARASSMENT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

model InterestRoom {
  id         String           @id @default(cuid())
  interestId String           @unique
  interest   Interest         @relation(fields: [interestId], references: [id])
  createdAt  DateTime         @default(now())
  messages   RoomMessage[]
  members    RoomMembership[]
}

model RoomMessage {
  id        String       @id @default(cuid())
  roomId    String
  room      InterestRoom @relation(fields: [roomId], references: [id])
  senderId  String
  sender    User         @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime     @default(now())
}

model RoomMembership {
  id       String       @id @default(cuid())
  roomId   String
  room     InterestRoom @relation(fields: [roomId], references: [id])
  userId   String
  user     User         @relation(fields: [userId], references: [id])
  joinedAt DateTime     @default(now())

  @@unique([roomId, userId])
}

