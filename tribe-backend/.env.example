# ─────────────────────────────────────────────────────────────────────────────
# Tribe Backend — Environment Variable Template
# Copy this file to .env and fill in all values before running docker-compose.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, self-hosted, etc.)
DATABASE_URL=postgresql://user:password@host:5432/tribe_db

# ── Authentication ────────────────────────────────────────────────────────────
# Long random string — generate with: openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret

# ── Socket.IO server ──────────────────────────────────────────────────────────
SOCKET_PORT=4000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
# Example: https://app.tribe.com,https://www.tribe.com
CORS_ORIGIN=http://localhost:3000

# ── Cloudinary (media uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Upstash Redis (JWT blacklist + rate limiting) ─────────────────────────────
# Get these from https://console.upstash.com → your Redis database → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Google Generative AI (Gemini — AI features) ───────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key

# ── AWS (optional — Rekognition content moderation) ──────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
